<?php
require_once '/usr/local/emhttp/plugins/docker-icon-manager/include/common.php';

// 处理设置保存
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    // 保存设置逻辑
    $settings = [
        'icon_dir' => $_POST['icon_dir'] ?? '/var/lib/docker/unraid/images/',
        'template_dir' => $_POST['template_dir'] ?? '/boot/config/plugins/dockerMan/templates-user/',
        'max_icon_size' => $_POST['max_icon_size'] ?? 2,
    ];
    // 保存设置到文件
    file_put_contents('/boot/config/plugins/docker-icon-manager/settings.json', json_encode($settings));
    $message = 'Settings saved successfully!';
}

// 加载当前设置
$settings = [
    'icon_dir' => '/var/lib/docker/unraid/images/',
    'template_dir' => '/boot/config/plugins/dockerMan/templates-user/',
    'max_icon_size' => 2,
];

if (file_exists('/boot/config/plugins/docker-icon-manager/settings.json')) {
    $loadedSettings = json_decode(file_get_contents('/boot/config/plugins/docker-icon-manager/settings.json'), true);
    if ($loadedSettings) {
        $settings = array_merge($settings, $loadedSettings);
    }
}
?>

