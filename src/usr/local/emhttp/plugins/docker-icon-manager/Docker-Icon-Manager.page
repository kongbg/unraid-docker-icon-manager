                            </td>
                            <td>
                                <?php if ($container['has_icon']): ?>
                                    <button class="btn btn-danger" onclick="deleteIcon('<?php echo $container['name']; ?>')">Delete Icon</button>
                                <?php else: ?>
                                    <span class="btn btn-disabled">No icon</span>
